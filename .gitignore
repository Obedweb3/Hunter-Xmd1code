# ============================================
# DYNAMICS 365 BUSINESS CENTRAL AL PROJECT
# Enhanced .gitignore - Production Ready
# ============================================

# ============================================
# IDE & EDITOR SETTINGS
# ============================================

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# Visual Studio
*.suo
*.user
*.userosscache
*.sln.docstates
.vs/

# JetBrains Rider / IntelliJ
.idea/
*.iml
*.iws
*.ipr
out/

# ============================================
# AL SPECIFIC - BUILD & CACHE
# ============================================

# AL Compiler Cache
.alcache/
.alpackages/

# Symbol Files (downloaded from NuGet/Container)
*.app
# Exception: Keep test apps if needed for deployment
!*.Test.app

# Rapid Application Development
rad.json
rad.*.json

# AL Build Output
.output/
build/

# Translation Files (auto-generated)
*.g.xlf
*.g.xlf.json

# License Files (NEVER commit - security sensitive)
*.flf
*.bclicense
*.bclicense.json

# Permission Sets (auto-generated)
*.permissionset.al
*.entitlement.al

# ============================================
# TESTING & QUALITY ASSURANCE
# ============================================

# Test Results
TestResults.xml
TestResults*.xml
*.trx
coverage.xml
codecoverage.json

# AL Test Runner Output
.altestrunner/
TestResults/

# Snapshot Debugging
.snapshots/
*.snapshot.json

# Performance Profiles
*.alprofile
*.vspscc

# ============================================
# PACKAGES & DEPENDENCIES
# ============================================

# NuGet Packages (restore on build)
packages/
*.nupkg
!**/packages/build/

# Node Modules (if using Node.js tools)
node_modules/
npm-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
# Exception: Keep lock files for CI/CD consistency
!**/ci-cd/package-lock.json

# ============================================
# SECRETS & CREDENTIALS (CRITICAL - NEVER COMMIT)
# ============================================

# Environment Configuration
.env
.env.*
!.env.example
!.env.template
config.env
secrets.json
appsettings*.json
!appsettings.json
!appsettings.example.json

# Azure / Cloud Credentials
*.publishsettings
*.pubxml
*.pubxml.user
azure.credentials.json
cloud.credentials.json

# Certificate Files
*.pfx
*.p12
*.cer
*.crt
*.key
*.pem
*.der

# API Keys & Tokens
*.apikey
*.token
*.secret
access_tokens.json
refresh_tokens.json

# Business Central Specific Secrets
*.bcconfig.json
!*.bcconfig.example.json
launch.json.private
tasks.json.private

# ============================================
# DATABASE & DATA FILES
# ============================================

# SQL Server Files
*.mdf
*.ldf
*.ndf
*.bak
*.trn

# Business Central Database Snapshots
*.bdsnapshot
*.navdata
*.navbak

# ============================================
# LOGS & TEMPORARY FILES
# ============================================

# Log Files
*.log
logs/
*.al.log
ALBuild.log
ALCompiler.log

# Temporary Files
*.tmp
*.temp
*.cache
*.swp
*.swo
*~
*.orig

# Crash Reports
crash-*.txt
error-*.json
stacktrace-*.txt

# ============================================
# OS SPECIFIC FILES
# ============================================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.nfs*
.directory
.Trash-*

# ============================================
# DEPLOYMENT & RELEASE
# ============================================

# Deployment Packages (build these in CI/CD)
*.zip
*.7z
*.tar.gz
releases/
artifacts/

# Docker Files (if using containers)
.dockerignore
docker-compose.override.yml
!docker-compose.yml
!Dockerfile

# Kubernetes
*.kubeconfig
k8s/secrets/

# ============================================
# DOCUMENTATION & GENERATED FILES
# ============================================

# Generated Documentation
docs/generated/
*.generated.md

# AL Object Documentation (auto-generated)
*.aldoc.json
aldoc/

# PowerShell Scripts (generated)
*.ps1.generated

# ============================================
# BACKUP & SYNC FILES
# ============================================

# Backup Files
*.bak
*.backup
*.old
*.orig
*.save

# Sync Tools
*.sync
*.sync-conflict*
SynoResource/

# OneDrive / Dropbox
*.onetmp
*.dropbox
.dropbox.attr

# ============================================
# EXCEPTIONS - KEEP THESE FILES
# ============================================

# AL Project Essentials
!app.json
!*.al
!**/src/**/*.al
!**/test/**/*.al

# Configuration Templates
!.vscode/settings.json.template
!.vscode/launch.json.template
!.vscode/tasks.json.template

# Documentation
!README.md
!CHANGELOG.md
!LICENSE
!CONTRIBUTING.md

# Pipeline Configuration
!.github/
!.azure-pipelines.yml
!.gitlab-ci.yml
!Jenkinsfile

# Scripts
!scripts/**/*.ps1
!scripts/**/*.sh
!scripts/**/*.cmd

# ============================================
# PROJECT SPECIFIC OVERRIDES
# Add your custom patterns below this line
# ============================================

# Example: Exclude specific custom add-ons
# MyCustomAddon.app

# Example: Exclude large data files
# *.demo-data.json
