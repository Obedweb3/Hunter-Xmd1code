{
  "name": "HUNTER XMD PRO",
  "description": "Javascript WhatsApp bot made by ObedTech",
  "logo": "https://files.catbox.moe/xka13x.jpg",
  "keywords": ["HUNTER-XMD", "whatsapp", "bot"],
  "repository": "https://github.com/Obedweb/Hunter-Xmd1",
  "stack": "heroku-24",
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "env": {
    "SESSION_ID": {
      "description": "Your WhatsApp session ID (base64 string starting with HUNTER-XMD~). Get it from the pairing process.",
      "required": true,
      "value": ""
    },
    "PREFIX": {
      "description": "Bot command prefix character.",
      "required": false,
      "value": "."
    },
    "MODE": {
      "description": "Bot mode: public, private, inbox, or group.",
      "required": false,
      "value": "public"
    },
    "BOT_NAME": {
      "description": "Name of the bot.",
      "required": false,
      "value": "HUNTER XMD PRO"
    },
    "OWNER_NAME": {
      "description": "Bot owner name.",
      "required": false,
      "value": "ObedTech"
    },
    "OWNER_NUMBER": {
      "description": "Bot owner WhatsApp number (with country code, no +).",
      "required": false,
      "value": "254794146821"
    },
    "AUTO_STATUS_SEEN": {
      "description": "Automatically view statuses.",
      "required": false,
      "value": "true"
    },
    "AUTO_STATUS_REACT": {
      "description": "Automatically react to statuses.",
      "required": false,
      "value": "true"
    },
    "AUTO_STATUS_REPLY": {
      "description": "Automatically reply to statuses.",
      "required": false,
      "value": "false"
    },
    "AUTO_STATUS_MSG": {
      "description": "Message to send when replying to a status.",
      "required": false,
      "value": "SEEN YOUR STATUS BY HUNTER XMD PRO"
    },
    "ALWAYS_ONLINE": {
      "description": "Keep the bot always online.",
      "required": false,
      "value": "true"
    },
    "AUTO_REPLY": {
      "description": "Automatically reply to messages.",
      "required": false,
      "value": "false"
    },
    "AUTO_REACT": {
      "description": "React to every incoming message.",
      "required": false,
      "value": "false"
    },
    "AUTO_VOICE": {
      "description": "Automatically send voice replies.",
      "required": false,
      "value": "false"
    },
    "AUTO_STICKER": {
      "description": "Automatically convert images to stickers.",
      "required": false,
      "value": "false"
    },
    "AUTO_TYPING": {
      "description": "Show typing indicator automatically.",
      "required": false,
      "value": "false"
    },
    "AUTO_RECORDING": {
      "description": "Show recording indicator automatically.",
      "required": false,
      "value": "true"
    },
    "ANTI_LINK": {
      "description": "Delete group links posted by non-admins.",
      "required": false,
      "value": "true"
    },
    "ANTI_LINK_KICK": {
      "description": "Kick members who post links in groups.",
      "required": false,
      "value": "false"
    },
    "ANTI_BAD": {
      "description": "Delete bad words in groups.",
      "required": false,
      "value": "true"
    },
    "ANTI_DEL_PATH": {
      "description": "Where to send deleted messages: 'log' (sender DM) or 'same' (same chat).",
      "required": false,
      "value": "log"
    },
    "ANTI_VV": {
      "description": "Reveal once-view messages.",
      "required": false,
      "value": "true"
    },
    "WELCOME": {
      "description": "Send welcome/goodbye messages in groups.",
      "required": false,
      "value": "true"
    },
    "ADMIN_EVENTS": {
      "description": "Notify when a member is promoted or demoted.",
      "required": false,
      "value": "false"
    },
    "MENTION_REPLY": {
      "description": "Auto-reply when the bot is mentioned.",
      "required": false,
      "value": "false"
    },
    "READ_MESSAGE": {
      "description": "Auto-read all incoming messages.",
      "required": false,
      "value": "false"
    },
    "READ_CMD": {
      "description": "Mark command messages as read.",
      "required": false,
      "value": "false"
    },
    "DELETE_LINKS": {
      "description": "Delete links from groups without kicking.",
      "required": false,
      "value": "false"
    },
    "STICKER_NAME": {
      "description": "Sticker pack name.",
      "required": false,
      "value": "HUNTER XMD PRO"
    },
    "ALIVE_IMG": {
      "description": "Image URL shown with the alive command.",
      "required": false,
      "value": "https://files.catbox.moe/k05k5r.jpg"
    },
    "MENU_IMAGE_URL": {
      "description": "Image URL shown with the menu command.",
      "required": false,
      "value": "https://files.catbox.moe/k05k5r.jpg"
    },
    "DESCRIPTION": {
      "description": "Bot description shown in the menu.",
      "required": false,
      "value": "Powered by ObedTech"
    },
    "CUSTOM_REACT": {
      "description": "Use custom reaction emojis.",
      "required": false,
      "value": "false"
    },
    "CUSTOM_REACT_EMOJIS": {
      "description": "Comma-separated list of custom reaction emojis.",
      "required": false,
      "value": "💝,💖,💗,❤️,🧡,💛,💚,💙,💜"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ]
}
